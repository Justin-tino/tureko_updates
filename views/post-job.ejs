<%- include('partials/header') %>

<section class="auth-page">
  <div class="platform-container">
    <div class="platform-header reveal">
      <a href="/jobs" class="platform-back">← My Job Listings</a>
      <h1>Post a New Job</h1>
      <p class="platform-subtitle">Create a green workforce opportunity</p>
    </div>

    <% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
    <div class="platform-alert platform-alert-error reveal">
      <% errors.forEach(function(err) { %>
      <p><%= err.msg %></p>
      <% }); %>
    </div>
    <% } %>

    <form method="POST" action="/jobs/post" class="platform-form reveal reveal-delay">
      <div class="form-group">
        <label for="title">Job Title *</label>
        <input type="text" id="title" name="title" value="<%= formData.title || '' %>" required placeholder="e.g. Sustainability Officer" />
      </div>

      <div class="form-grid">
        <div class="form-group">
          <label for="category">Category *</label>
          <select id="category" name="category" required>
            <option value="">Select a category...</option>
            <% categories.forEach(function(cat) { %>
            <option value="<%= cat %>" <%= formData.category === cat ? 'selected' : '' %>><%= cat %></option>
            <% }); %>
          </select>
        </div>
        <div class="form-group">
          <label for="type">Job Type *</label>
          <select id="type" name="type" required>
            <option value="">Select type...</option>
            <% jobTypes.forEach(function(t) { %>
            <option value="<%= t %>" <%= formData.type === t ? 'selected' : '' %>><%= t.charAt(0).toUpperCase() + t.slice(1) %></option>
            <% }); %>
          </select>
        </div>
      </div>

      <div class="form-group">
        <label for="location">Location *</label>
        <input type="text" id="location" name="location" value="<%= formData.location || '' %>" required placeholder="e.g. Manila, Philippines" />
      </div>

      <div class="form-group">
        <label for="salaryRange">Salary Range <span class="form-hint">(optional)</span></label>
        <input type="text" id="salaryRange" name="salaryRange" value="<%= formData.salaryRange || '' %>" placeholder="e.g. ₱25,000 - ₱40,000 / month" />
      </div>

      <div class="form-group">
        <label for="description">Job Description *</label>
        <textarea id="description" name="description" rows="6" required placeholder="Describe the role, responsibilities, and what makes this opportunity unique..."><%= formData.description || '' %></textarea>
      </div>

      <div class="form-group">
        <label for="requirements">Requirements <span class="form-hint">(optional)</span></label>
        <textarea id="requirements" name="requirements" rows="4" placeholder="List qualifications, skills, and experience needed..."><%= formData.requirements || '' %></textarea>
      </div>

      <div class="form-actions">
        <a href="/jobs" class="btn-outline">Cancel</a>
        <button type="submit" class="btn-submit">Publish Job</button>
      </div>
    </form>
  </div>
</section>

<%- include('partials/footer') %>
