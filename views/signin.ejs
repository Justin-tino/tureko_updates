<%- include('partials/header') %>

<section class="auth-page">
  <div class="auth-split">
    <!-- Left panel — branding -->
    <div class="auth-brand-panel">
      <div class="auth-brand-inner">
        <div class="auth-brand-logo">
          <img src="/images/logo.jpg" alt="Tureko" />
          <span>tureko</span>
        </div>
        <h1>Welcome to Tureko</h1>
        <p>Join the leading sustainability and green workforce platform. Connect with climate-responsible businesses and opportunities worldwide.</p>
        <div class="auth-brand-features">
          <div class="auth-feature">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span>Green workforce placement</span>
          </div>
          <div class="auth-feature">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span>Sustainability consulting</span>
          </div>
          <div class="auth-feature">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span>Climate program access</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Right panel — sign in / sign up form -->
    <div class="auth-form-panel">
      <div class="auth-form-inner">
        <!-- Mode toggle -->
        <div class="auth-mode-tabs">
          <button class="auth-tab active" id="tabSignIn" data-mode="signin">Sign In</button>
          <button class="auth-tab" id="tabSignUp" data-mode="signup">Sign Up</button>
        </div>

        <!-- Error / Success toast -->
        <div class="auth-toast" id="authToast">
          <span class="auth-toast-icon" id="authToastIcon"></span>
          <span class="auth-toast-msg" id="authToastMsg"></span>
        </div>

        <!-- SIGN IN FORM -->
        <form class="auth-form" id="signinForm">
          <h2>Sign in to your account</h2>
          <p class="auth-subtitle">Enter your credentials below</p>

          <div class="auth-field">
            <label for="signinEmail">Email address</label>
            <div class="auth-input-wrap">
              <svg class="auth-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              <input type="email" id="signinEmail" name="email" placeholder="you@example.com" required autocomplete="email" />
            </div>
          </div>

          <div class="auth-field">
            <label for="signinPassword">Password</label>
            <div class="auth-input-wrap">
              <svg class="auth-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              <input type="password" id="signinPassword" name="password" placeholder="••••••••" required autocomplete="current-password" />
              <button type="button" class="auth-pw-toggle" aria-label="Show password" data-target="signinPassword">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              </button>
            </div>
          </div>

          <div class="auth-extras">
            <button type="button" class="auth-forgot" id="forgotPasswordBtn">Forgot password?</button>
          </div>

          <button type="submit" class="btn-submit auth-submit" id="signinSubmit">
            <span>Sign In</span>
            <div class="btn-loader" style="display:none"></div>
          </button>
        </form>

        <!-- SIGN UP FORM -->
        <form class="auth-form" id="signupForm" style="display:none">
          <h2>Create your account</h2>
          <p class="auth-subtitle">Start your sustainability journey</p>

          <!-- Role selector -->
          <div class="auth-field">
            <label>I want to join as</label>
            <div class="auth-role-selector" id="roleSelector">
              <button type="button" class="auth-role-card" data-role="applicant">
                <div class="auth-role-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                </div>
                <div class="auth-role-text">
                  <strong>Applicant</strong>
                  <span>Find green jobs &amp; build your career</span>
                </div>
                <div class="auth-role-check">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
              </button>
              <button type="button" class="auth-role-card" data-role="business">
                <div class="auth-role-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
                </div>
                <div class="auth-role-text">
                  <strong>Business</strong>
                  <span>Post jobs &amp; find green talent</span>
                </div>
                <div class="auth-role-check">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
              </button>
            </div>
            <input type="hidden" id="signupRole" name="role" value="" required />
          </div>

          <div class="auth-field">
            <label for="signupName">Full name</label>
            <div class="auth-input-wrap">
              <svg class="auth-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              <input type="text" id="signupName" name="name" placeholder="John Doe" required autocomplete="name" />
            </div>
          </div>

          <div class="auth-field">
            <label for="signupEmail">Email address</label>
            <div class="auth-input-wrap">
              <svg class="auth-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              <input type="email" id="signupEmail" name="email" placeholder="you@example.com" required autocomplete="email" />
            </div>
          </div>

          <div class="auth-field">
            <label for="signupPassword">Password</label>
            <div class="auth-input-wrap">
              <svg class="auth-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              <input type="password" id="signupPassword" name="password" placeholder="••••••••" required autocomplete="new-password" minlength="8" />
              <button type="button" class="auth-pw-toggle" aria-label="Show password" data-target="signupPassword">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              </button>
            </div>
            <!-- Password strength meter -->
            <div class="pw-strength" id="pwStrength">
              <div class="pw-bar"><div class="pw-bar-fill" id="pwBarFill"></div></div>
              <span class="pw-label" id="pwLabel"></span>
            </div>
            <ul class="pw-rules" id="pwRules">
              <li id="rule-length">At least 8 characters</li>
              <li id="rule-upper">One uppercase letter</li>
              <li id="rule-number">One number</li>
              <li id="rule-special">One special character (!@#$%...)</li>
            </ul>
          </div>

          <div class="auth-field">
            <label for="signupConfirm">Confirm password</label>
            <div class="auth-input-wrap">
              <svg class="auth-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              <input type="password" id="signupConfirm" name="confirmPassword" placeholder="••••••••" required autocomplete="new-password" />
            </div>
          </div>

          <button type="submit" class="btn-submit auth-submit" id="signupSubmit">
            <span>Create Account</span>
            <div class="btn-loader" style="display:none"></div>
          </button>
        </form>

        <!-- FORGOT PASSWORD FORM -->
        <form class="auth-form" id="forgotForm" style="display:none">
          <h2>Reset your password</h2>
          <p class="auth-subtitle">We'll send a password reset link to your email</p>

          <div class="auth-field">
            <label for="forgotEmail">Email address</label>
            <div class="auth-input-wrap">
              <svg class="auth-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              <input type="email" id="forgotEmail" name="email" placeholder="you@example.com" required autocomplete="email" />
            </div>
          </div>

          <button type="submit" class="btn-submit auth-submit" id="forgotSubmit">
            <span>Send Reset Link</span>
            <div class="btn-loader" style="display:none"></div>
          </button>

          <button type="button" class="auth-back-link" id="backToSignIn">← Back to Sign In</button>
        </form>

        <!-- Divider -->
        <div class="auth-divider" id="authDivider">
          <span>or continue with</span>
        </div>

        <!-- Google sign-in -->
        <button type="button" class="auth-google-btn" id="googleSignInBtn">
          <svg viewBox="0 0 24 24" width="20" height="20">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          <span>Sign in with Google</span>
        </button>

        <p class="auth-terms">
          By signing in, you agree to Tureko's
          <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a>.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- Firebase Client SDK (compat) -->
<script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-auth-compat.js"></script>

<script>
  // Inject Firebase config from server
  window.__FIREBASE_CONFIG__ = <%- firebaseConfig %>;
</script>
<script src="/js/auth.js"></script>

<%- include('partials/footer') %>
