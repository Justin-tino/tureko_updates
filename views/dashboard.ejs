<%- include('partials/header') %>

<section class="auth-page">
  <div class="dashboard-container">
    <div class="dashboard-header reveal">
      <div class="dashboard-avatar">
        <% if (user.picture) { %>
          <img src="<%= user.picture %>" alt="" referrerpolicy="no-referrer" />
        <% } else { %>
          <span class="dashboard-initial"><%= user.name.charAt(0).toUpperCase() %></span>
        <% } %>
      </div>
      <div class="dashboard-welcome">
        <span class="section-label">Dashboard</span>
        <h1>Welcome back, <%= user.name %></h1>
        <p><%= user.email %> · <span class="role-badge role-<%= user.role %>"><%= user.role === 'business' ? 'Business' : 'Applicant' %></span></p>
      </div>
    </div>

    <% if (user.role === 'business') { %>
    <!-- BUSINESS DASHBOARD -->
    <div class="dashboard-grid reveal reveal-delay">
      <a href="/profile" class="dashboard-card dashboard-card-link">
        <div class="dashboard-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
        </div>
        <h3>Company Profile</h3>
        <p>Manage your company information and details.</p>
        <% if (!user.profileComplete) { %><span class="dashboard-card-badge badge-action">Complete Profile</span><% } %>
      </a>

      <a href="/jobs/post" class="dashboard-card dashboard-card-link">
        <div class="dashboard-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        </div>
        <h3>Post a Job</h3>
        <p>Create a new green job listing for applicants.</p>
      </a>

      <a href="/jobs" class="dashboard-card dashboard-card-link">
        <div class="dashboard-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
        </div>
        <h3>My Job Listings</h3>
        <p>Manage your posted jobs and view applicants.</p>
        <span class="dashboard-card-stat"><%= stats.jobs %> job<%= stats.jobs !== 1 ? 's' : '' %></span>
      </a>

      <a href="/applications" class="dashboard-card dashboard-card-link">
        <div class="dashboard-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        </div>
        <h3>Applications Received</h3>
        <p>Review and manage applicant submissions.</p>
        <span class="dashboard-card-stat"><%= stats.applications %> received</span>
      </a>

      <a href="/settings" class="dashboard-card dashboard-card-link">
        <div class="dashboard-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
        </div>
        <h3>Settings</h3>
        <p>Update preferences and account settings.</p>
      </a>
    </div>

    <% } else { %>
    <!-- APPLICANT DASHBOARD -->
    <div class="dashboard-grid reveal reveal-delay">
      <a href="/profile" class="dashboard-card dashboard-card-link">
        <div class="dashboard-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
        <h3>My Profile</h3>
        <p>Manage your skills, experience, and bio.</p>
        <% if (!user.profileComplete) { %><span class="dashboard-card-badge badge-action">Complete Profile</span><% } %>
      </a>

      <a href="/jobs" class="dashboard-card dashboard-card-link">
        <div class="dashboard-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
        </div>
        <h3>Browse Jobs</h3>
        <p>Find green workforce opportunities near you.</p>
        <span class="dashboard-card-stat"><%= stats.jobs %> open</span>
      </a>

      <a href="/applications" class="dashboard-card dashboard-card-link">
        <div class="dashboard-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        </div>
        <h3>My Applications</h3>
        <p>Track your submitted applications and status.</p>
        <span class="dashboard-card-stat"><%= stats.applications %> sent</span>
      </a>

      <a href="/settings" class="dashboard-card dashboard-card-link">
        <div class="dashboard-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
        </div>
        <h3>Settings</h3>
        <p>Update preferences and account settings.</p>
      </a>
    </div>
    <% } %>

    <div class="dashboard-signout reveal">
      <form action="/auth/session-logout" method="POST">
        <button type="submit" class="btn-outline">Sign Out</button>
      </form>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
