<%- include('partials/header') %>

<section class="auth-page">
  <div class="platform-container">
    <div class="platform-header reveal">
      <a href="/dashboard" class="platform-back">← Dashboard</a>
      <h1><%= user.role === 'business' ? 'My Job Listings' : 'Job Board' %></h1>
      <p class="platform-subtitle"><%= user.role === 'business' ? 'Manage your posted jobs and view applicants' : 'Find green workforce opportunities' %></p>
    </div>

    <% if (user.role === 'business') { %>
    <div class="platform-actions reveal">
      <a href="/jobs/post" class="btn-submit">+ Post a New Job</a>
    </div>
    <% } %>

    <% if (jobs.length === 0) { %>
    <div class="platform-empty reveal reveal-delay">
      <div class="platform-empty-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
      </div>
      <% if (user.role === 'business') { %>
      <h3>No jobs posted yet</h3>
      <p>Create your first green job listing to attract sustainability talent.</p>
      <a href="/jobs/post" class="btn-submit">Post a Job</a>
      <% } else { %>
      <h3>No open positions right now</h3>
      <p>Check back soon — new green workforce opportunities are added regularly.</p>
      <% } %>
    </div>
    <% } else { %>
    <div class="job-list reveal reveal-delay">
      <% jobs.forEach(function(job) { %>
      <a href="/jobs/<%= job.id %>" class="job-card">
        <div class="job-card-top">
          <div class="job-card-info">
            <h3><%= job.title %></h3>
            <p class="job-card-company"><%= job.businessName %></p>
          </div>
          <% if (user.role === 'business') { %>
          <span class="status-badge status-<%= job.status %>"><%= job.status %></span>
          <% } %>
        </div>
        <div class="job-card-meta">
          <span class="job-meta-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <%= job.location %>
          </span>
          <span class="job-meta-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
            <%= job.type %>
          </span>
          <% if (job.category) { %>
          <span class="job-meta-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
            <%= job.category %>
          </span>
          <% } %>
        </div>
        <% if (job.description) { %>
        <p class="job-card-desc"><%= job.description.substring(0, 150) %><%= job.description.length > 150 ? '...' : '' %></p>
        <% } %>
        <div class="job-card-bottom">
          <% if (job.salaryRange) { %>
          <span class="job-salary"><%= job.salaryRange %></span>
          <% } %>
          <% if (user.role === 'business') { %>
          <span class="job-applicants"><%= job.applicantCount || 0 %> applicant<%= (job.applicantCount || 0) !== 1 ? 's' : '' %></span>
          <% } %>
          <span class="job-view-link">View Details →</span>
        </div>
      </a>
      <% }); %>
    </div>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
